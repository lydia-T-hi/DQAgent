# DQ Multi-Agent Pipeline — 환경변수 예시
# 이 파일을 복사해서 .env로 저장 후 실제 키를 입력하세요
# cp .env.example .env

# OpenAI API 키 (Stage 3A 활성화 시 필요, --skip-openai 사용 시 불필요)
OPENAI_API_KEY=sk-proj-...

# Anthropic API 키 (설정하지 않는 것을 권장)
# Stage 2B는 Claude CLI OAuth를 사용합니다.
# 이 키가 설정되면 OAuth 대신 API 크레딧을 소모합니다.
# ANTHROPIC_API_KEY=sk-ant-...
